ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=mabuntle;Username=mabuntle;Password=change_me

POSTGRES_DB=mabuntle
POSTGRES_USER=mabuntle
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

MABUNTLE_WEB_API_BASE_URL=https://localhost:7268
MABUNTLE_API_BASE_URL=https://localhost:7268

Jwt__Issuer=Mabuntle.Api
Jwt__Audience=Mabuntle.Web
Jwt__SigningKey=change_me_minimum_32_characters_for_local_development
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=14

AuthCookies__RefreshTokenPath=/api/auth
AuthCookies__CsrfPath=/
AuthCookies__Domain=
AuthCookies__SameSite=Lax
AuthCookies__Secure=true

Cors__AllowedOrigins__0=http://localhost:4200
Cors__AllowedOrigins__1=https://localhost:4200

PaymentProvider__ProviderName=Fake
PaymentProvider__DefaultCurrency=ZAR
PaymentProvider__SuccessRedirectUrl=http://localhost:4200/checkout/success
PaymentProvider__FailureRedirectUrl=http://localhost:4200/checkout/failed
PaymentProvider__WebhookSigningSecret=
PaymentProvider__FakeOutcome=Success
# Production may use PaymentProvider__ProviderName=Disabled until PayFast is configured.

PaymentWebhookPayloadRetention__Enabled=true
PaymentWebhookPayloadRetention__RetentionDays=90
PaymentWebhookPayloadRetention__BatchSize=500

ImageStorage__ProviderName=Local
ImageStorage__LocalRootPath=storage/product-images
ImageStorage__PublicBasePath=/media/product-images
ImageStorage__MaxFileBytes=5242880
ImageStorage__MaxPixelWidth=8000
ImageStorage__MaxPixelHeight=8000
ImageStorage__VariantWebpQuality=82
ImageStorage__AllowedContentTypes__0=image/jpeg
ImageStorage__AllowedContentTypes__1=image/png
ImageStorage__AllowedContentTypes__2=image/webp
ImageStorage__S3__BucketName=
ImageStorage__S3__Region=af-south-1
ImageStorage__S3__ServiceUrl=
ImageStorage__S3__PublicBaseUrl=
ImageStorage__S3__KeyPrefix=product-images
ImageStorage__S3__ForcePathStyle=true
ImageStorage__S3__AccessKeyId=
ImageStorage__S3__SecretAccessKey=
MediaScanning__ProviderName=TrustLocalClean
MediaScanning__RequireExternalScannerInProduction=false
MediaCleanup__GracePeriodHours=24
MediaCleanup__BatchSize=50

SellerVerificationEvidence__LocalRootPath=storage/seller-verification-evidence
SellerVerificationEvidence__MaxFileBytes=10485760
SellerVerificationEvidence__MaxActiveFilesPerSeller=20
SellerVerificationEvidence__AllowedContentTypes__0=application/pdf
SellerVerificationEvidence__AllowedContentTypes__1=image/jpeg
SellerVerificationEvidence__AllowedContentTypes__2=image/png
SellerVerificationEvidence__AllowedContentTypes__3=image/webp

EmailDelivery__ProviderName=LogOnly
EmailDelivery__FromAddress=
EmailDelivery__FromName=Mabuntle
EmailDelivery__AppBaseUrl=http://localhost:4200
EmailDelivery__BatchSize=25
EmailDelivery__MaxAttempts=5
EmailDelivery__RetryMinutes=15
# Production Resend SMTP example:
# EmailDelivery__ProviderName=Smtp
# EmailDelivery__FromAddress=no-reply@mail.mabuntle.com
# EmailDelivery__Smtp__Host=smtp.resend.com
# EmailDelivery__Smtp__Username=resend
# EmailDelivery__Smtp__Password=<resend-api-key>
EmailDelivery__Smtp__Host=
EmailDelivery__Smtp__Port=587
EmailDelivery__Smtp__Username=
EmailDelivery__Smtp__Password=
EmailDelivery__Smtp__EnableSsl=true

CarrierProvider__ProviderName=Manual
CarrierProvider__Fake__TrackingBaseUrl=http://localhost:4200/fake-tracking
CarrierProvider__Fake__LabelBaseUrl=http://localhost:4200/fake-label
CarrierTracking__BatchSize=25
CarrierTracking__SyncIntervalMinutes=15

# Future carrier-provider placeholders. Leave all values empty unless a real adapter is implemented.
# Supported runtime CarrierProvider__ProviderName values today: Manual, Fake.
# Bob Go is the preferred first real adapter candidate once API docs and sandbox credentials are available.
CarrierProvider__BobGo__ApiKey=
CarrierProvider__BobGo__SandboxBaseUrl=
CarrierProvider__BobGo__ProductionBaseUrl=
CarrierProvider__BobGo__WebhookSigningSecret=
# PUDO is the fallback candidate if Bob Go technical access is blocked.
CarrierProvider__Pudo__ApiKey=
CarrierProvider__Pudo__BaseUrl=

SupportOperations__OpenSlaHours=24
SupportOperations__EscalatedSlaHours=4
SupportOperations__DueSoonHours=4
SupportQuality__DefaultRangeDays=30
SupportQuality__MaxRangeDays=366
SupportQuality__FirstResponseTargetHours=4
SupportQuality__ResolutionTargetHours=72

# Provider placeholders. Leave credential values empty unless configuring a real provider locally.
# Supported values for PaymentProvider__ProviderName: Fake, Disabled, PayFast. PayU is documented but not implemented.
PayFast__MerchantId=
PayFast__MerchantKey=
PayFast__Passphrase=
PayFast__ProcessUrl=
PayFast__ValidateUrl=
PayFast__NotifyUrl=
PayFast__CheckoutBridgeBaseUrl=
PayFast__RequireRemoteValidation=true

PayU__Region=SouthAfrica
PayU__Username=
PayU__Password=
PayU__Safekey=
PayU__PaymentPageUrl=
PayU__WebhookSigningKey=

PayoutProvider__ProviderName=Fake
PayoutProvider__FakeOutcome=PaidOut

Ledger__PlatformCommissionRatePercent=10
Ledger__PaymentProviderFeeRatePercent=2.5
Ledger__PaymentProviderFixedFee=0

MabuntleRateLimits__Auth__PermitLimit=30
MabuntleRateLimits__Auth__WindowSeconds=60
MabuntleRateLimits__Webhook__PermitLimit=120
MabuntleRateLimits__Webhook__WindowSeconds=60
MabuntleRateLimits__AdImpression__PermitLimit=300
MabuntleRateLimits__AdImpression__WindowSeconds=60
MabuntleRateLimits__StorefrontAnalytics__PermitLimit=300
MabuntleRateLimits__StorefrontAnalytics__WindowSeconds=60

MABUNTLE_RUN_POSTGRES_TESTS=false
MABUNTLE_TEST_POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=mabuntle_integration_tests;Username=mabuntle;Password=change_me
