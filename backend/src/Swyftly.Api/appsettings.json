{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "Swyftly.Api",
    "Audience": "Swyftly.Web",
    "SigningKey": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "AuthCookies": {
    "RefreshTokenPath": "/api/auth",
    "CsrfPath": "/",
    "Domain": "",
    "SameSite": "Lax",
    "Secure": true
  },
  "PaymentProvider": {
    "ProviderName": "Fake",
    "DefaultCurrency": "ZAR",
    "SuccessRedirectUrl": "http://localhost:4200/checkout/success",
    "FailureRedirectUrl": "http://localhost:4200/checkout/failed",
    "WebhookSigningSecret": "",
    "FakeOutcome": "Success"
  },
  "PaymentWebhookPayloadRetention": {
    "Enabled": true,
    "RetentionDays": 90,
    "BatchSize": 500
  },
  "ImageStorage": {
    "ProviderName": "Local",
    "LocalRootPath": "storage/product-images",
    "PublicBasePath": "/media/product-images",
    "MaxFileBytes": 5242880,
    "MaxPixelWidth": 8000,
    "MaxPixelHeight": 8000,
    "VariantWebpQuality": 82,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ],
    "S3": {
      "BucketName": "",
      "Region": "af-south-1",
      "ServiceUrl": "",
      "PublicBaseUrl": "",
      "KeyPrefix": "product-images",
      "ForcePathStyle": true,
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "CacheControl": "public, max-age=31536000, immutable"
    }
  },
  "MediaScanning": {
    "ProviderName": "TrustLocalClean",
    "RequireExternalScannerInProduction": false
  },
  "MediaCleanup": {
    "GracePeriodHours": 24,
    "BatchSize": 50
  },
  "SellerVerificationEvidence": {
    "LocalRootPath": "storage/seller-verification-evidence",
    "MaxFileBytes": 10485760,
    "MaxActiveFilesPerSeller": 20,
    "AllowedContentTypes": [
      "application/pdf",
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  },
  "EmailDelivery": {
    "ProviderName": "LogOnly",
    "FromAddress": "",
    "FromName": "Swyftly",
    "AppBaseUrl": "http://localhost:4200",
    "BatchSize": 25,
    "MaxAttempts": 5,
    "RetryMinutes": 15,
    "Smtp": {
      "Host": "",
      "Port": 587,
      "Username": "",
      "Password": "",
      "EnableSsl": true
    }
  },
  "CarrierProvider": {
    "ProviderName": "Manual",
    "Fake": {
      "TrackingBaseUrl": "http://localhost:4200/fake-tracking",
      "LabelBaseUrl": "http://localhost:4200/fake-label"
    }
  },
  "CarrierTracking": {
    "BatchSize": 25,
    "SyncIntervalMinutes": 15
  },
  "SupportOperations": {
    "OpenSlaHours": 24,
    "EscalatedSlaHours": 4,
    "DueSoonHours": 4
  },
  "SupportQuality": {
    "DefaultRangeDays": 30,
    "MaxRangeDays": 366,
    "FirstResponseTargetHours": 4,
    "ResolutionTargetHours": 72
  },
  "PayFast": {
    "MerchantId": "",
    "MerchantKey": "",
    "Passphrase": "",
    "ProcessUrl": "",
    "ValidateUrl": "",
    "NotifyUrl": "",
    "CheckoutBridgeBaseUrl": "",
    "RequireRemoteValidation": true
  },
  "PayU": {
    "Region": "SouthAfrica",
    "Username": "",
    "Password": "",
    "Safekey": "",
    "PaymentPageUrl": "",
    "WebhookSigningKey": ""
  },
  "PayoutProvider": {
    "ProviderName": "Fake",
    "FakeOutcome": "PaidOut"
  },
  "Ledger": {
    "PlatformCommissionRatePercent": 10,
    "PaymentProviderFeeRatePercent": 2.5,
    "PaymentProviderFixedFee": 0
  },
  "SwyftlyRateLimits": {
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Ai": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "ProductWrite": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "Payment": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Webhook": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    },
    "AdImpression": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    },
    "AdClick": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    },
    "StorefrontAnalytics": {
      "PermitLimit": 180,
      "WindowSeconds": 60
    },
    "Search": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
