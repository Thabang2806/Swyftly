{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "mabuntle-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/mabuntle-web",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "styles",
                "output": "styles"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "server": "src/main.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "650kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "cloudflare": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cloudflare.ts"
                }
              ]
            },
            "client-cloudflare": {
              "outputPath": "dist/mabuntle-client",
              "browser": "src/main.ts",
              "tsConfig": "tsconfig.client.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cloudflare.ts"
                }
              ]
            },
            "seller-cloudflare": {
              "outputPath": "dist/mabuntle-seller",
              "browser": "src/main.seller.ts",
              "tsConfig": "tsconfig.seller.json",
              "prerender": false,
              "ssr": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cloudflare.ts"
                }
              ]
            },
            "admin-cloudflare": {
              "outputPath": "dist/mabuntle-admin",
              "browser": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "prerender": false,
              "ssr": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cloudflare.ts"
                }
              ]
            },
            "client-development": {
              "outputPath": "dist/mabuntle-client-dev",
              "browser": "src/main.ts",
              "tsConfig": "tsconfig.client.json",
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "prerender": false,
              "ssr": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "seller-development": {
              "outputPath": "dist/mabuntle-seller-dev",
              "browser": "src/main.seller.ts",
              "tsConfig": "tsconfig.seller.json",
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "prerender": false,
              "ssr": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "admin-development": {
              "outputPath": "dist/mabuntle-admin-dev",
              "browser": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "prerender": false,
              "ssr": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "mabuntle-web:build:production"
            },
            "development": {
              "buildTarget": "mabuntle-web:build:development"
            },
            "client": {
              "buildTarget": "mabuntle-web:build:client-development",
              "port": 4200
            },
            "seller": {
              "buildTarget": "mabuntle-web:build:seller-development",
              "port": 4201
            },
            "admin": {
              "buildTarget": "mabuntle-web:build:admin-development",
              "port": 4202
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "styles",
                "output": "styles"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
